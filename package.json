{
  "name": "cloudflare-expression-lint",
  "version": "0.1.17",
  "description": "A parser, validator, and linter for Cloudflare Rules Language expressions with phase-aware field and function checking",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cf-expr-lint": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./eslint-plugin": {
      "import": "./dist/eslint-plugin.js",
      "types": "./dist/eslint-plugin.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CLAUDE.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "sync-docs": "tsx scripts/sync-cloudflare-docs.ts",
    "sync-docs:apply": "tsx scripts/sync-cloudflare-docs.ts --apply"
  },
  "keywords": [
    "cloudflare",
    "expression",
    "lint",
    "validator",
    "parser",
    "firewall",
    "waf",
    "terraform",
    "wirefilter",
    "rules-language"
  ],
  "author": "Troy Jones",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/troymjones/cloudflare-expression-lint.git"
  },
  "bugs": {
    "url": "https://github.com/troymjones/cloudflare-expression-lint/issues"
  },
  "homepage": "https://github.com/troymjones/cloudflare-expression-lint#readme",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "glob": "^10.3.10",
    "yaml": "^2.3.4"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0",
    "yaml-eslint-parser": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    },
    "yaml-eslint-parser": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
